#!/usr/bin/env zsh

#Set path to the docker binary on your machine
DOCKER=/Applications/Docker.app/Contents/Resources/bin/docker

work_dir=$PWD

if [[ "$1" == --* ]]; then
    $DOCKER exec kira kira "$@"
    exit $?
fi

if [[ $# -eq 0 ]]; then
    echo "Error: No input file provided." >&2
    exit 1
fi

input_file=$1

if [[ ! -f "$input_file" ]]; then
    echo "Error: Input file '$input_file' does not exist." >&2
    exit 3
fi

echo "Starting kira process with input file: $input_file" >&2

$DOCKER exec kira sh -c "rm -rf *"
$DOCKER cp "$work_dir/." kira:/home/jobs/
$DOCKER exec kira sh -c "kira $input_file"

$DOCKER cp kira:/home/jobs/sectormappings "$work_dir"
$DOCKER cp kira:/home/jobs/tmp "$work_dir"
$DOCKER cp kira:/home/jobs/results "$work_dir"

echo "Kira process completed." >&2
exit 0